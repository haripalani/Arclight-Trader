# Database
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=trading_db
DATABASE_URL=postgresql://postgres:root@postgres:5432/trading_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=arclight_secure_pass_123 # Required for engine deduplication

# API
PORT=3001
FRONTEND_URL=http://localhost:9000

# Engine
ENGINE_URL=http://engine:8000
SYSTEM_API_KEY=your_system_api_key_here # Shared secret between API and Engine
USER_ID=your_user_id_here

# Binance Settings
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true # Set to false for live trading
CONFIRM_LIVE_TRADING=no # Must be 'yes' to trade with real funds if TESTNET=false

# MiroFish (LLM Signal Adapter)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.mulerouter.ai/v1
LLM_MODEL_NAME=qwen/qwen-2.5-72b-instruct
MIROFISH_URL=http://mirofish:5000

# Telegram Alerting
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
