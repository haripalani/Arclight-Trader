{
  "name": "trading-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "shared"
  ],
  "scripts": {
    "web:dev": "npm run dev -w apps/web",
    "api:dev": "npm run start:dev -w apps/api",
    "engine:dev": "cd apps/engine && uvicorn main:app --reload",
    "dev": "concurrently \"npm run web:dev\" \"npm run api:dev\" \"npm run engine:dev\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "prisma": {
    "seed": "ts-node apps/api/prisma/seed.ts"
  }
}
